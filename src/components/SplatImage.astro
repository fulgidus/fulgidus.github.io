---
/**
 * SplatImage — Drop-in replacement for Astro's <Image> with SplatHash blur placeholder.
 *
 * At build time, encodes the image into a 16-byte SplatHash stored in `data-splat`.
 * A CSS background-color (average color from the hash) provides an immediate
 * no-JS fallback. A client-side decoder (splat-decode.ts) reads `data-splat`,
 * decodes it to a 32x32 blur, and sets it as a canvas-rendered background-image.
 *
 * Usage:
 *   <SplatImage src={image} alt="description" format="webp" class="my-class" />
 *
 * Accepts all props that Astro's <Image> accepts. The `src` must be an ImageMetadata
 * object from a content collection (with `fsPath` available).
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { generatePlaceholder } from '@/utils/splathash';

interface Props {
  src: ImageMetadata;
  alt: string | null;
  class?: string;
  style?: string;
  loading?: 'lazy' | 'eager';
  format?: 'webp' | 'avif' | 'png' | 'jpeg';
  [key: string]: any;
}

const { src, alt, style, ...rest } = Astro.props;

// Generate the blur placeholder at build time
let splatHash: string | undefined;
let avgColorStyle: string | undefined;
try {
  if ((src as any).fsPath) {
    const { hash, avgColor } = await generatePlaceholder((src as any).fsPath);
    splatHash = hash;
    avgColorStyle = `background-color:${avgColor};`;
  }
} catch (e) {
  // Silently fall back to no placeholder if encoding fails
  console.warn(`[SplatImage] Failed to generate placeholder for ${alt}:`, e);
}

// Merge avg-color background with any user-provided inline style
const mergedStyle = [avgColorStyle, style].filter(Boolean).join('') || undefined;
---

<Image
  src={src}
  alt={alt}
  style={mergedStyle}
  data-splat={splatHash || undefined}
  {...rest}
/>
