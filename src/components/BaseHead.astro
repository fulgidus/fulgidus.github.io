---
import siteConfig from "@/site-config";
import "@/styles/global.css";
import "@/styles/prose.css";
import "@/styles/dot.css";
import { defaultLang, Languages, ui } from "@/i18n/ui";
import { useSpecificPath, translateFrom, getLangFromUrl } from "@/i18n/utils";
import { getHreflangLinks } from "@/utils/hreflang";
import {
  buildArticleJsonLd,
  buildPersonJsonLd,
  buildWebSiteJsonLd,
  buildBreadcrumbJsonLd,
} from "@/utils/jsonld";

interface Props {
  title?: string;
  description?: string;
  image?: { src: string; alt?: string };
  ogImage?: string;
  pageType?: "website" | "article" | "profile";
  noindex?: boolean;
  postSlug?: string;
  pubDate?: string | Date;
  tags?: string[];
  readingTime?: string;
}

const {
  description = siteConfig.description,
  image = siteConfig.siteImage,
  ogImage,
  pageType = "website",
  noindex = false,
  postSlug,
  pubDate,
  tags,
  readingTime,
} = Astro.props;

const title = [Astro.props.title, siteConfig.title].filter(Boolean).join(" | ");

// Use dynamic OG image if provided, otherwise fall back to the post/site image
const resolvedImage = ogImage
  ? {
      src: new URL(ogImage, Astro.site).toString(),
      alt: Astro.props.title || siteConfig.title,
    }
  : image?.src
    ? {
        src: new URL(image.src, Astro.site).toString(),
        alt: image.alt,
      }
    : undefined;

const canonicalURL = new URL(Astro.request.url, Astro.site);

function formatCanonicalURL(url: string | URL) {
  const path = url.toString();
  const hasQueryParams = path.includes("?");
  if (hasQueryParams) path.replace(/\/?$/, "");
  return path.replace(/\/?$/, hasQueryParams ? "" : "/");
}

const availableLanguages = Object.keys(ui) as Languages[];
const currentLang = getLangFromUrl(Astro.url);

// Hreflang alternate links for SEO
const hreflangLinks = await getHreflangLinks(
  canonicalURL,
  Astro.site ?? siteConfig.title,
  postSlug,
);

// JSON-LD structured data
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://fulgidus.github.io';
const pageUrl = formatCanonicalURL(canonicalURL);

function buildJsonLd(): Record<string, unknown> {
  if (pageType === 'article' && Astro.props.title) {
    return buildArticleJsonLd({
      title: Astro.props.title,
      description,
      url: pageUrl,
      siteUrl,
      imageUrl: resolvedImage?.src,
      pubDate,
      tags,
      readingTime,
    });
  }

  if (pageType === 'profile') {
    return buildPersonJsonLd({ siteUrl });
  }

  // Default: WebSite schema
  return buildWebSiteJsonLd(siteUrl);
}

const jsonLd = buildJsonLd();

// Breadcrumb structured data (null for homepage)
const breadcrumbJsonLd = buildBreadcrumbJsonLd({
  url: pageUrl,
  siteUrl,
  lang: currentLang,
  pageTitle: Astro.props.title,
  labels: {},
});
---

<!-- High Priority Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>{title}</title>
<meta name="generator" content={Astro.generator} />

<!-- Low Priority Global Metadata -->
<link rel="icon" type="image/svg+xml" href={siteConfig.header.logo.src} />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
  rel="alternate"
  type="application/rss+xml"
  href={"/rss.xml"}
  title="All posts in English"
  lang="en"
/>
<link
  rel="alternate"
  type="application/rss+xml"
  href={"/last-ten.xml"}
  title="Last 10 posts in English"
  lang="en"
/>
<link
  rel="alternate"
  type="application/feed+json"
  href={"/feed.json"}
  title="All posts in English (JSON Feed)"
  lang="en"
/>
{
  availableLanguages
    .filter((l) => l !== "en" && !ui[l]["disabled"])
    .map((lang) => {
      if (lang !== defaultLang) {
        return (
          <>
            <link
              rel="alternate"
              type="application/rss+xml"
              href={useSpecificPath(lang, `/rss.xml`)}
              title={translateFrom(lang, "rss.titleAll")}
              lang={lang}
            />
            <link
              rel="alternate"
              type="application/rss+xml"
              href={useSpecificPath(lang, `/last-ten.xml`)}
              title={translateFrom(lang, "rss.titleLastTen")}
              lang={lang}
            />
            <link
              rel="alternate"
              type="application/feed+json"
              href={useSpecificPath(lang, `/feed.json`)}
              title={`${translateFrom(lang, "rss.titleAll")} (JSON Feed)`}
              lang={lang}
            />
          </>
        );
      }
    })
}

<!-- Page Metadata -->
<link rel="canonical" href={formatCanonicalURL(canonicalURL)} />
<meta name="description" content={description} />
<meta name="theme-color" content="#380541" />
{noindex && <meta name="robots" content="noindex, nofollow" />}

<!-- Hreflang alternate links -->
{hreflangLinks.map((link) => (
  <link rel="alternate" hreflang={link.lang} href={link.href} />
))}

<!-- LLM-friendly content -->
<link rel="alternate" type="text/plain" href="/llms.txt" title="LLMs.txt - LLM-friendly site content" />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={pageType} />
<meta property="og:url" content={formatCanonicalURL(canonicalURL)} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
{resolvedImage?.src && <meta property="og:image" content={resolvedImage.src} />}
{
  resolvedImage?.alt && (
    <meta property="og:image:alt" content={resolvedImage.alt} />
  )
}

<!-- X / Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={formatCanonicalURL(canonicalURL)} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
{
  resolvedImage?.src && (
    <meta property="twitter:image" content={resolvedImage.src} />
  )
}
{
  resolvedImage?.alt && (
    <meta name="twitter:image:alt" content={resolvedImage?.alt} />
  )
}

<!-- JSON-LD structured data -->
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
{breadcrumbJsonLd && (
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
)}

<script>
  import nprogress from "nprogress";

  document.addEventListener("astro:before-preparation", () => {
    nprogress.start();
  });

  document.addEventListener("astro:page-load", () => {
    nprogress.done();
  });

  // Code copy button injection
  function initCopyButtons() {
    document.querySelectorAll('.prose pre').forEach((pre) => {
      if (pre.querySelector('.copy-code-btn')) return;
      const btn = document.createElement('button');
      btn.className = 'copy-code-btn';
      btn.setAttribute('aria-label', 'Copy code to clipboard');

      const icon = document.createElement('i');
      icon.className = 'i-ri-file-copy-line';
      btn.appendChild(icon);

      btn.addEventListener('click', async () => {
        const code = pre.querySelector('code');
        const text = code ? code.textContent || '' : pre.textContent || '';
        try {
          await navigator.clipboard.writeText(text);
          icon.className = 'i-ri-check-line';
          btn.classList.add('copied');
          setTimeout(() => {
            icon.className = 'i-ri-file-copy-line';
            btn.classList.remove('copied');
          }, 2000);
        } catch {
          icon.className = 'i-ri-error-warning-line';
          setTimeout(() => { icon.className = 'i-ri-file-copy-line'; }, 2000);
        }
      });
      pre.appendChild(btn);
    });
  }
  document.addEventListener('astro:page-load', initCopyButtons);

  // Anchor link click-to-copy handler
  function initAnchorLinks() {
    document.querySelectorAll<HTMLAnchorElement>('.prose .anchor-link').forEach((link) => {
      if (link.dataset.copyInit) return;
      link.dataset.copyInit = 'true';

      link.addEventListener('click', async (e) => {
        e.preventDefault();
        const href = link.getAttribute('href');
        if (!href) return;
        const url = window.location.origin + window.location.pathname + href;
        const iconSpan = link.querySelector('.anchor-icon');
        if (!iconSpan) return;

        try {
          await navigator.clipboard.writeText(url);
          const original = iconSpan.innerHTML;
          iconSpan.innerHTML = '<svg width="0.85em" height="0.85em" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>';
          setTimeout(() => { iconSpan.innerHTML = original; }, 1500);
        } catch {
          // Silently fail if clipboard not available
        }
      });
    });
  }
  document.addEventListener('astro:page-load', initAnchorLinks);
</script>
<script
  defer
  src="https://cloud.umami.is/script.js"
  data-website-id="e4492488-53e1-4115-8b3b-f07c527d973b"></script>

