---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Search" description="Search blog posts">
  <div class="max-w-4xl mx-auto">
    <div class="prose">
      <h1>Search</h1>
    </div>
    <div id="search" class="search-container">
      <input
        type="text"
        id="search-input"
        placeholder="Search posts..."
        class="search-input"
        aria-label="Search posts"
        autofocus
      />
      <div id="search-results" class="search-results"></div>
    </div>
  </div>
</BaseLayout>

<script is:inline>
  (function() {
    var initialized = false;

    async function initPagefind() {
      if (initialized) return;
      var input = document.getElementById('search-input');
      var results = document.getElementById('search-results');
      if (!input || !results) return;
      initialized = true;

      var pagefind = null;
      try {
        pagefind = await import('/pagefind/pagefind.js');
        await pagefind.options({ ranking: { pageLength: 0.5 } });
      } catch (e) {
        results.innerHTML = '<p class="search-no-results">Search index not available. Please try again later.</p>';
        return;
      }

      var debounceTimer;

      input.addEventListener('input', function() {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(async function() {
          var query = input.value.trim();
          results.innerHTML = '';

          if (!query) return;

          var search = await pagefind.search(query, { language: 'en' });

          if (search.results.length === 0) {
            results.innerHTML = '<p class="search-no-results">No results found.</p>';
            return;
          }

          for (var i = 0; i < Math.min(search.results.length, 10); i++) {
            var data = await search.results[i].data();
            var item = document.createElement('a');
            item.href = data.url;
            item.className = 'search-result-item';

            var title = data.meta && data.meta.title ? data.meta.title : 'Untitled';
            var excerpt = data.excerpt || '';

            item.innerHTML =
              '<span class="search-result-title">' + title + '</span>' +
              '<span class="search-result-excerpt">' + excerpt + '</span>';
            results.appendChild(item);
          }
        }, 200);
      });

      input.focus();
    }

    document.addEventListener('astro:page-load', function() {
      initialized = false;
      initPagefind();
    });

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initPagefind);
    } else {
      initPagefind();
    }
  })();
</script>

<style is:global>
  .search-container {
    margin-top: 1.5rem;
  }

  .search-input {
    width: 100%;
    padding: 0.75rem 1rem;
    font-size: 1rem;
    border: 1px solid rgba(128, 128, 128, 0.25);
    border-radius: 0.5rem;
    background: transparent;
    color: inherit;
    outline: none;
    transition: border-color 0.2s;
    font-family: inherit;
  }

  .search-input:focus {
    border-color: rgba(128, 128, 128, 0.5);
  }

  .search-input::placeholder {
    opacity: 0.5;
  }

  .search-results {
    margin-top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .search-result-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0.75rem 1rem;
    border-radius: 0.375rem;
    text-decoration: none !important;
    color: inherit;
    transition: background-color 0.15s;
    border: 1px solid transparent;
  }

  .search-result-item:hover {
    background: rgba(128, 128, 128, 0.08);
    border-color: rgba(128, 128, 128, 0.15);
  }

  .search-result-title {
    font-weight: 600;
    font-size: 1.05rem;
    line-height: 1.4;
  }

  .search-result-excerpt {
    font-size: 0.85rem;
    opacity: 0.6;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .search-result-excerpt mark {
    background: rgba(255, 200, 0, 0.25);
    color: inherit;
    border-radius: 2px;
    padding: 0 2px;
  }

  .search-no-results {
    opacity: 0.5;
    text-align: center;
    padding: 2rem;
    font-size: 0.95rem;
  }
</style>
