---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Search" description="Search blog posts">
  <div class="max-w-4xl mx-auto">
    <h1 class="text-2xl font-bold mb-4">Search</h1>
    <div id="search" class="search-container">
      <input
        type="text"
        id="search-input"
        placeholder="Search posts..."
        class="search-input"
        aria-label="Search posts"
        autofocus
      />
      <div id="search-results" class="search-results"></div>
    </div>
  </div>
</BaseLayout>

<script is:inline>
  document.addEventListener('astro:page-load', async function() {
    var input = document.getElementById('search-input');
    var results = document.getElementById('search-results');
    if (!input || !results) return;

    // Abort any previous event listeners from prior navigations
    if (window.__pagefindAbort) {
      window.__pagefindAbort.abort();
    }
    window.__pagefindAbort = new AbortController();
    var signal = window.__pagefindAbort.signal;

    // Always destroy + re-init so pagefind reads the current <html lang>
    try {
      if (!window.__pagefind) {
        window.__pagefind = await import('/pagefind/pagefind.js');
      } else {
        await window.__pagefind.destroy();
      }
      await window.__pagefind.options({ ranking: { pageLength: 0.5 } });
      await window.__pagefind.init();
    } catch (e) {
      results.innerHTML = '<p class="search-no-results">Search index not available. Please try again later.</p>';
      return;
    }

    var pagefind = window.__pagefind;
    var debounceTimer;

    input.addEventListener('input', function() {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(async function() {
        var query = input.value.trim();

        if (!query) {
          results.innerHTML = '';
          return;
        }

        var search = await pagefind.search(query);

        if (search.results.length === 0) {
          results.innerHTML = '<p class="search-no-results">No results found.</p>';
          return;
        }

        var newResults = document.createDocumentFragment();

        var loaded = await Promise.all(
          search.results.slice(0, 10).map(function(r) { return r.data(); })
        );

        for (var i = 0; i < loaded.length; i++) {
          var data = loaded[i];
          var item = document.createElement('a');
          item.href = data.url;
          item.className = 'search-result-item';
          item.style.animationDelay = (i * 30) + 'ms';

          var title = data.meta && data.meta.title ? data.meta.title : 'Untitled';
          var excerpt = data.excerpt || '';

          item.innerHTML =
            '<span class="search-result-title">' + title + '</span>' +
            '<span class="search-result-excerpt">' + excerpt + '</span>';
          newResults.appendChild(item);
        }

        results.innerHTML = '';
        results.appendChild(newResults);
      }, 200);
    }, { signal: signal });

    input.focus();
  });
</script>

<style is:global>
  .search-input {
    width: 100%;
    padding: 0.75rem 1rem;
    font-size: 1rem;
    border: 1px solid rgba(128, 128, 128, 0.25);
    border-radius: 0.5rem;
    background: transparent;
    color: inherit;
    outline: none;
    transition: border-color 0.2s;
    font-family: inherit;
  }

  .search-input:focus {
    border-color: rgba(128, 128, 128, 0.5);
  }

  .search-input::placeholder {
    opacity: 0.5;
  }

  .search-results {
    margin-top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  @keyframes searchResultFadeIn {
    from {
      opacity: 0;
      transform: translateY(6px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .search-result-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0.75rem 1rem;
    border-radius: 0.375rem;
    text-decoration: none !important;
    color: inherit;
    transition: background-color 0.15s, border-color 0.15s;
    border: 1px solid transparent;
    animation: searchResultFadeIn 0.25s ease-out both;
  }

  .search-result-item:hover {
    background: rgba(128, 128, 128, 0.08);
    border-color: rgba(128, 128, 128, 0.15);
  }

  .search-result-title {
    font-weight: 600;
    font-size: 1.05rem;
    line-height: 1.4;
  }

  .search-result-excerpt {
    font-size: 0.85rem;
    opacity: 0.6;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .search-result-excerpt mark {
    background: rgba(255, 200, 0, 0.25);
    color: inherit;
    border-radius: 2px;
    padding: 0 2px;
  }

  .search-no-results {
    opacity: 0.5;
    text-align: center;
    padding: 2rem;
    font-size: 0.95rem;
  }
</style>
