---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Cerca" description="Cerca negli articoli del blog">
  <div class="prose max-w-4xl mx-auto">
    <h1>Cerca</h1>
    <div id="search" class="search-container">
      <input
        type="text"
        id="search-input"
        placeholder="Cerca articoli..."
        class="search-input"
        aria-label="Cerca articoli"
      />
      <div id="search-results" class="search-results"></div>
    </div>
  </div>
</BaseLayout>

<script is:inline>
  (function() {
    var initialized = false;

    async function initPagefind() {
      if (initialized) return;
      var input = document.getElementById('search-input');
      var results = document.getElementById('search-results');
      if (!input || !results) return;
      initialized = true;

      var pagefind = null;
      try {
        pagefind = await import('/pagefind/pagefind.js');
      } catch (e) {
        results.innerHTML = '<p class="search-no-results">Indice di ricerca non disponibile. Riprova più tardi.</p>';
        return;
      }

      var debounceTimer;

      input.addEventListener('input', function() {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(async function() {
          var query = input.value.trim();
          results.innerHTML = '';

          if (!query) return;

          var search = await pagefind.search(query);

          if (search.results.length === 0) {
            results.innerHTML = '<p class="search-no-results">Nessun risultato trovato.</p>';
            return;
          }

          for (var i = 0; i < Math.min(search.results.length, 10); i++) {
            var data = await search.results[i].data();
            var item = document.createElement('a');
            item.href = data.url;
            item.className = 'search-result-item';
            item.innerHTML =
              '<span class="search-result-title">' + (data.meta && data.meta.title ? data.meta.title : 'Senza titolo') + '</span>' +
              '<span class="search-result-excerpt">' + data.excerpt + '</span>';
            results.appendChild(item);
          }
        }, 200);
      });

      input.focus();
    }

    document.addEventListener('astro:page-load', function() {
      initialized = false;
      initPagefind();
    });

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initPagefind);
    } else {
      initPagefind();
    }
  })();
</script>

<style is:global>
  .search-container {
    margin-top: 1rem;
  }

  .search-input {
    width: 100%;
    padding: 0.75rem 1rem;
    font-size: 1rem;
    border: 2px solid rgba(128, 128, 128, 0.3);
    border-radius: 0.5rem;
    background: transparent;
    color: inherit;
    outline: none;
    transition: border-color 0.2s;
  }

  .search-input:focus {
    border-color: rgba(128, 128, 128, 0.6);
  }

  .search-input::placeholder {
    opacity: 0.5;
  }

  .search-results {
    margin-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .search-result-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0.75rem 1rem;
    border-radius: 0.5rem;
    text-decoration: none;
    color: inherit;
    transition: background-color 0.15s;
  }

  .search-result-item:hover {
    background: rgba(128, 128, 128, 0.1);
  }

  .search-result-title {
    font-weight: 600;
    font-size: 1.05rem;
  }

  .search-result-excerpt {
    font-size: 0.875rem;
    opacity: 0.7;
    line-height: 1.5;
  }

  .search-result-excerpt mark {
    background: rgba(255, 200, 0, 0.3);
    color: inherit;
    border-radius: 2px;
    padding: 0 2px;
  }

  .search-no-results {
    opacity: 0.5;
    text-align: center;
    padding: 2rem;
  }
</style>
