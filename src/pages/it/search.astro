---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Cerca" description="Cerca negli articoli del blog">
  <div class="max-w-4xl mx-auto">
    <h1 class="text-2xl font-bold mb-4">Cerca</h1>
    <div id="search" class="search-container">
      <input
        type="text"
        id="search-input"
        placeholder="Cerca articoli..."
        class="search-input"
        aria-label="Cerca articoli"
        role="combobox"
        aria-expanded="false"
        aria-controls="search-results"
        aria-autocomplete="list"
        autofocus
      />
      <div id="search-results" role="listbox" class="search-results"></div>
    </div>
  </div>
</BaseLayout>

<script is:inline>
  document.addEventListener('astro:page-load', async function() {
    var input = document.getElementById('search-input');
    var results = document.getElementById('search-results');
    if (!input || !results) return;

    // Abort any previous event listeners from prior navigations
    if (window.__pagefindAbort) {
      window.__pagefindAbort.abort();
    }
    window.__pagefindAbort = new AbortController();
    var signal = window.__pagefindAbort.signal;

    // Always destroy + re-init so pagefind reads the current <html lang>
    try {
      if (!window.__pagefind) {
        window.__pagefind = await import('/pagefind/pagefind.js');
      } else {
        await window.__pagefind.destroy();
      }
      await window.__pagefind.options({ ranking: { pageLength: 0.5 } });
      await window.__pagefind.init();
    } catch (e) {
      results.innerHTML = '<p class="search-no-results">Indice di ricerca non disponibile. Riprova più tardi.</p>';
      return;
    }

    var pagefind = window.__pagefind;
    var debounceTimer;
    var activeIndex = -1;

    function getResultType(url) {
      if (/\/(it\/)?posts\//.test(url)) return 'Blog';
      if (/\/(it\/)?projects\//.test(url)) return 'Progetto';
      if (/\/(it\/)?tags\//.test(url)) return 'Tag';
      return 'Pagina';
    }

    function getResultTypeClass(url) {
      if (/\/(it\/)?posts\//.test(url)) return 'blog';
      if (/\/(it\/)?projects\//.test(url)) return 'project';
      if (/\/(it\/)?tags\//.test(url)) return 'tag';
      return 'page';
    }

    async function performSearch(query) {
      if (!query) {
        results.innerHTML = '';
        input.setAttribute('aria-expanded', 'false');
        activeIndex = -1;
        return;
      }

      var search = await pagefind.search(query);

      if (search.results.length === 0) {
        results.innerHTML = '<p class="search-no-results">Nessun risultato trovato.</p>';
        input.setAttribute('aria-expanded', 'false');
        activeIndex = -1;
        return;
      }

      var newResults = document.createDocumentFragment();
      activeIndex = -1;

      var loaded = await Promise.all(
        search.results.slice(0, 10).map(function(r) { return r.data(); })
      );

      for (var i = 0; i < loaded.length; i++) {
        var data = loaded[i];
        var item = document.createElement('a');
        item.href = data.url;
        item.className = 'search-result-item';
        item.setAttribute('role', 'option');
        item.setAttribute('aria-selected', 'false');
        item.id = 'search-result-' + i;
        item.style.animationDelay = (i * 30) + 'ms';

        var title = data.meta && data.meta.title ? data.meta.title : 'Senza titolo';
        var excerpt = data.excerpt || '';
        var type = getResultType(data.url);
        var typeClass = getResultTypeClass(data.url);

        item.innerHTML =
          '<span class="search-result-header">' +
            '<span class="search-result-title">' + title + '</span>' +
            '<span class="search-result-type search-result-type--' + typeClass + '">' + type + '</span>' +
          '</span>' +
          '<span class="search-result-excerpt">' + excerpt + '</span>';
        newResults.appendChild(item);
      }

      results.innerHTML = '';
      results.appendChild(newResults);
      input.setAttribute('aria-expanded', 'true');
    }

    function updateUrl(query) {
      var url = new URL(window.location.href);
      if (query) {
        url.searchParams.set('s', query);
      } else {
        url.searchParams.delete('s');
      }
      history.replaceState(null, '', url.toString());
    }

    function setActiveResult(index) {
      var items = results.querySelectorAll('.search-result-item');
      if (items.length === 0) return;

      // Remove active from all
      for (var i = 0; i < items.length; i++) {
        items[i].classList.remove('search-result-active');
        items[i].setAttribute('aria-selected', 'false');
      }

      if (index < 0) {
        activeIndex = -1;
        input.removeAttribute('aria-activedescendant');
        return;
      }

      if (index >= items.length) index = items.length - 1;
      activeIndex = index;
      items[index].classList.add('search-result-active');
      items[index].setAttribute('aria-selected', 'true');
      input.setAttribute('aria-activedescendant', items[index].id);
      items[index].scrollIntoView({ block: 'nearest' });
    }

    // Keyboard navigation
    input.addEventListener('keydown', function(e) {
      var items = results.querySelectorAll('.search-result-item');

      if (e.key === 'ArrowDown') {
        e.preventDefault();
        if (items.length > 0) {
          setActiveResult(Math.min(activeIndex + 1, items.length - 1));
        }
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        if (activeIndex > 0) {
          setActiveResult(activeIndex - 1);
        } else {
          setActiveResult(-1);
        }
      } else if (e.key === 'Enter' && activeIndex >= 0 && items[activeIndex]) {
        e.preventDefault();
        items[activeIndex].click();
      } else if (e.key === 'Escape') {
        e.preventDefault();
        if (input.value) {
          input.value = '';
          results.innerHTML = '';
          updateUrl('');
          activeIndex = -1;
          input.setAttribute('aria-expanded', 'false');
        } else {
          input.blur();
        }
      }
    }, { signal: signal });

    // Input handler with debounce
    input.addEventListener('input', function() {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(async function() {
        var query = input.value.trim();
        updateUrl(query);
        await performSearch(query);
      }, 200);
    }, { signal: signal });

    // Read ?s= from URL on page load
    var urlParams = new URLSearchParams(window.location.search);
    var initialQuery = urlParams.get('s');
    if (initialQuery) {
      input.value = initialQuery;
      await performSearch(initialQuery);
    }

    input.focus();
  });
</script>

<style is:global>
  .search-input {
    width: 100%;
    padding: 0.75rem 1rem;
    font-size: 1rem;
    border: 1px solid rgba(128, 128, 128, 0.25);
    border-radius: 0.5rem;
    background: transparent;
    color: inherit;
    outline: none;
    transition: border-color 0.2s;
    font-family: inherit;
  }

  .search-input:focus-visible {
    border-color: rgba(128, 128, 128, 0.5);
    outline: 2px solid currentColor;
    outline-offset: 2px;
  }

  .search-input::placeholder {
    opacity: 0.5;
  }

  .search-results {
    margin-top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  @keyframes searchResultFadeIn {
    from {
      opacity: 0;
      transform: translateY(6px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .search-result-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0.75rem 1rem;
    border-radius: 0.375rem;
    text-decoration: none !important;
    color: inherit;
    transition: background-color 0.15s, border-color 0.15s;
    border: 1px solid transparent;
    animation: searchResultFadeIn 0.25s ease-out both;
  }

  .search-result-item:hover,
  .search-result-item.search-result-active {
    background: rgba(128, 128, 128, 0.08);
    border-color: rgba(128, 128, 128, 0.15);
  }

  .search-result-item.search-result-active {
    outline: 2px solid currentColor;
    outline-offset: -2px;
  }

  .search-result-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .search-result-title {
    font-weight: 600;
    font-size: 1.05rem;
    line-height: 1.4;
  }

  .search-result-type {
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.1rem 0.4rem;
    border-radius: 0.25rem;
    opacity: 0.7;
    border: 1px solid rgba(128, 128, 128, 0.2);
    line-height: 1.4;
    flex-shrink: 0;
  }

  .search-result-type--blog {
    border-color: rgba(59, 130, 246, 0.3);
    color: rgb(59, 130, 246);
  }

  .search-result-type--project {
    border-color: rgba(16, 185, 129, 0.3);
    color: rgb(16, 185, 129);
  }

  .search-result-type--tag {
    border-color: rgba(168, 85, 247, 0.3);
    color: rgb(168, 85, 247);
  }

  .search-result-excerpt {
    font-size: 0.85rem;
    opacity: 0.6;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .search-result-excerpt mark {
    background: rgba(255, 200, 0, 0.25);
    color: inherit;
    border-radius: 2px;
    padding: 0 2px;
  }

  .search-no-results {
    opacity: 0.5;
    text-align: center;
    padding: 2rem;
    font-size: 0.95rem;
  }
</style>
