---
import GoBackToBlog from "@/components/GoBackToBlog.vue";
import GiscusComments from "@/components/GiscusComments.vue";
import LanguageFlag from "@/components/LanguageFlags.vue";
import ReadingProgress from "@/components/ReadingProgress.vue";
import RelatedPosts from "@/components/RelatedPosts.astro";
import SeriesNavigation from "@/components/SeriesNavigation.astro";
import SharePost from "@/components/SharePost.vue";
import TagsList from "@/components/TagsList.vue";
import { Languages } from "@/i18n/ui";
import { getLangFromSlug, getLangFromUrl, useTranslate } from "@/i18n/utils";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { composeImageSizeClasses } from "@/pages/posts/[...slug].astro";
import { type CollectionPost } from "@/types";
import { getPosts, removeLangFromSlug } from "@/utils/posts";
import { getOgImagePath } from "@/utils/og";
import SplatImage from "@/components/SplatImage.astro";

export async function getStaticPaths() {
  const posts = await getPosts({
    lang: "it",
    withUnlisted: true,
    withDrafts: true,
  }); // This need to be with unlisted, otherwise they won't ever exist in SSG

  const returnedPosts = posts.map((post: CollectionPost) => ({
    params: { slug: removeLangFromSlug(post.slug) },
    props: {
      post,
    },
  }));
  return returnedPosts;
}

type Props = { post: CollectionPost };

const { post }: Props = Astro.props;
const {
  title,
  image,
  imageAlt,
  imageSize,
  description,
  pubDate,
  duration,
  tags,
  draft,
  unlisted,
  series,
} = post.data;
const { slug } = post;

const { Content, remarkPluginFrontmatter } = await post.render();

// Use remark-computed reading time, with manual duration as fallback/override
const readingTime = duration || remarkPluginFrontmatter?.duration;

// Fetch all IT posts for related posts component
const allItPosts = await getPosts({ lang: "it" }) as CollectionPost[];

function getDate(date: string) {
  return new Date(date).toISOString();
}

const articleImage = {
  src: image?.src ?? "",
  alt: imageAlt,
};

const ogImage = await getOgImagePath(slug, {
  title,
  description,
  pubDate,
});

const currentLang = getLangFromUrl(Astro.url.pathname);
// Dynamically construct languages array based on available translations
// const availableLanguages = Object.keys(ui) as (Languages)[];
// const languages = availableLanguages.map((lang) => [lang, ui[lang].language]);
const t = useTranslate(currentLang as Languages);
// const tp = useTranslatedPath(currentLang as Languages);
---

<!-- ACTUAL POST RENDERER -->
<BaseLayout
  title={title}
  description={description}
  image={articleImage}
  ogImage={ogImage}
  pageType="article"
  imageSize={imageSize}
  noindex={unlisted}
  postSlug={slug}
  pubDate={pubDate}
  tags={tags}
  readingTime={readingTime}
>
  <ReadingProgress client:only="vue" />
  <!-- <a
    title="Back"
    href="javascript:history.back()"
    style="button"
    float-end
    m-s-10
    m-t-1
  >
    <i aria-label="Go back" i-ri-arrow-go-back-line></i>
  </a> -->
  <article class="prose" data-pagefind-body>
    <div class="max-w-4xl mx-auto relative">
      <h1 transition:name={`post-title-${slug.replace(/\//g, '-')}`}>
        {title}
      </h1>
      <!-- {
        unlisted && (
          <div h-initial class="flex flex-wrap flex-gap-1 important-m-0">
            <span class="important-m-0 important-p-0 underline text-red">
              {t("slug.unlisted")}
            </span>
          </div>
        )
      } -->
      {
        draft && (
          <div h-initial class="flex flex-wrap flex-gap-1 important-m-0">
            <span class="important-m-0 important-p-0 underline text-red">
              {t("slug.draft")}
            </span>
          </div>
        )
      }
      <p h-initial class="flex flex-wrap flex-gap-1" data-pagefind-ignore>
        {
          pubDate && (
            <time datetime={getDate(pubDate)}>{pubDate.split(",")}</time>
          )
        }
        {readingTime && <span>· {readingTime}</span>}
        {"· "}
        <LanguageFlag lang={getLangFromSlug(slug)} client:only="vue" verbose />
        <SharePost shareTitle={title} client:only="vue" />
      </p>
    </div>
    {
      image && (
        <SplatImage
          src={image}
          alt={imageAlt || ""}
          loading="lazy"
          class={composeImageSizeClasses(imageSize)}
          format="webp"
        />
      )
    }
    <Content />
    {series && <SeriesNavigation currentSlug={slug} series={series} lang="it" />}
    <div class="!mt-10 !mb--10" data-pagefind-ignore>
      <SharePost shareTitle={title} client:only="vue" />
      {
        tags && tags.length > 0 && (
          <span class="flex flex-wrap flex-gap-1 py1rem !mt-10 !mb--10">
            <TagsList tags={tags} link={true} verbose noDot />
          </span>
        )
      }
    </div>
    <ul>
      <GoBackToBlog client:only="vue" />
    </ul>
  </article>

  {!draft && !unlisted && (
    <RelatedPosts currentPost={post} allPosts={allItPosts} lang="it" />
  )}

  {!draft && !unlisted && <GiscusComments client:only="vue" />}
</BaseLayout>
