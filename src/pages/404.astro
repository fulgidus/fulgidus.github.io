---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getLangFromUrl, translateFrom, translatePath, getActiveLanguages } from "@/i18n/utils";
import { getLastTenPosts, getHref, removeLangFromSlug } from "@/utils/posts";
import { ui, defaultLang, type Languages } from "@/i18n/ui";

// Build-time: collect translations for all active languages (only 404.* keys)
const activeLanguages = getActiveLanguages();

const translationKeys = [
  '404.title',
  '404.description',
  '404.backButtonLabel',
  '404.terminalError',
  '404.terminalHint',
  '404.terminalHelp',
] as const;

type TranslationKey = typeof translationKeys[number];

const i18nData: Record<string, Record<string, string>> = {};
for (const lang of activeLanguages) {
  i18nData[lang] = {};
  for (const key of translationKeys) {
    i18nData[lang][key] = translateFrom(lang, key);
  }
}

// Locale map for date formatting (matches src/utils/date.ts)
const localeMap: Record<string, string> = {
  en: 'en-GB',
  it: 'it-IT',
  nl: 'nl-NL',
};

// Build-time: collect posts for each active language
type PostData = {
  href: string;
  slug: string;
  dateISO: string;
};

const postsData: Record<string, PostData[]> = {};
for (const lang of activeLanguages) {
  const recentPosts = await getLastTenPosts({ lang });
  const postsToShow = recentPosts.slice(0, 5);
  postsData[lang] = postsToShow.map((post) => ({
    href: translatePath(getHref(post), lang),
    slug: removeLangFromSlug(post.slug),
    dateISO: new Date(post.data.pubDate).toISOString(),
  }));
}

// Build-time: compute home paths for each language
const homePaths: Record<string, string> = {};
for (const lang of activeLanguages) {
  homePaths[lang] = translatePath('/', lang);
}

// Use default language for initial SSR render (will be swapped client-side)
const currentLang = defaultLang;
const t = (key: Parameters<typeof translateFrom>[1]) => translateFrom(currentLang, key);
---

<BaseLayout
  title={t('404.title')}
  description={t('404.description')}
>
  <div class="terminal-wrapper" role="region" aria-label="404 Error">
    <div class="terminal-titlebar">
      <div class="terminal-controls">
        <span class="terminal-dot dot-close"></span>
        <span class="terminal-dot dot-minimize"></span>
        <span class="terminal-dot dot-maximize"></span>
      </div>
      <span class="terminal-title" data-i18n="titlebar">bash - 404</span>
      <div class="terminal-controls-spacer"></div>
    </div>
    <div class="terminal-body">
      <h1 class="sr-only" data-i18n="404.title">{t('404.title')}</h1>
      <div class="terminal-line">
        <span class="terminal-prompt">
          <span class="prompt-user">visitor</span><span class="prompt-at">@</span><span class="prompt-host">fulgidus.github.io</span><span class="prompt-colon">:</span><span class="prompt-path">~</span><span class="prompt-dollar">$</span>
        </span>
        <span class="terminal-command" id="typed-path"></span>
        <span class="terminal-cursor">_</span>
      </div>

      <div class="terminal-line terminal-error" data-i18n="404.terminalError">
        {t('404.terminalError')}
      </div>

      <div class="terminal-line terminal-empty"></div>

      <div class="terminal-line">
        <span class="terminal-prompt">
          <span class="prompt-user">visitor</span><span class="prompt-at">@</span><span class="prompt-host">fulgidus.github.io</span><span class="prompt-colon">:</span><span class="prompt-path">~</span><span class="prompt-dollar">$</span>
        </span>
        <span class="terminal-command">ls ./posts/</span>
      </div>

      <div class="terminal-line terminal-hint" data-i18n="404.terminalHint">
        # {t('404.terminalHint')}
      </div>

      <div class="terminal-ls" id="posts-listing">
        {/* Posts will be rendered client-side from embedded JSON */}
      </div>

      <div class="terminal-line terminal-empty"></div>

      <div class="terminal-line">
        <span class="terminal-prompt">
          <span class="prompt-user">visitor</span><span class="prompt-at">@</span><span class="prompt-host">fulgidus.github.io</span><span class="prompt-colon">:</span><span class="prompt-path">~</span><span class="prompt-dollar">$</span>
        </span>
        <span class="terminal-command">cd <a id="home-link" href={translatePath('/', currentLang)} class="terminal-link" data-astro-prefetch>~/<span data-i18n="404.backButtonLabel">{t('404.backButtonLabel')}</span></a></span>
      </div>

      <div class="terminal-line terminal-help" data-i18n="404.terminalHelp">
        # {t('404.terminalHelp')}
      </div>

      <div class="terminal-line">
        <span class="terminal-prompt">
          <span class="prompt-user">visitor</span><span class="prompt-at">@</span><span class="prompt-host">fulgidus.github.io</span><span class="prompt-colon">:</span><span class="prompt-path">~</span><span class="prompt-dollar">$</span>
        </span>
        <span class="terminal-cursor blink">_</span>
      </div>
    </div>
  </div>
</BaseLayout>

<script is:inline define:vars={{
  i18nData: JSON.stringify(i18nData),
  postsData: JSON.stringify(postsData),
  homePaths: JSON.stringify(homePaths),
  localeMap: JSON.stringify(localeMap),
  defaultLang,
  activeLanguages: JSON.stringify(activeLanguages),
}}>
  (function() {
    // Parse embedded data
    var translations = JSON.parse(i18nData);
    var posts = JSON.parse(postsData);
    var homes = JSON.parse(homePaths);
    var locales = JSON.parse(localeMap);
    var langs = JSON.parse(activeLanguages);

    // Detect language from URL path (mirrors getLangFromUrl from i18n/utils.ts)
    function detectLang() {
      var parts = window.location.pathname.split('/');
      var langSegment = parts[1] || '';
      if (langs.indexOf(langSegment) !== -1) {
        return langSegment;
      }
      return defaultLang;
    }

    var lang = detectLang();
    var t = translations[lang] || translations[defaultLang];
    var locale = locales[lang] || locales[defaultLang] || 'en-GB';

    // Determine the "open" command prefix per language
    var openCmd = lang === 'it' ? 'apri' : lang === 'nl' ? 'open' : 'open';

    // Update typed path with localized command
    var pathEl = document.getElementById('typed-path');
    if (pathEl) {
      pathEl.textContent = openCmd + ' ' + window.location.pathname;
    }

    // Update all data-i18n elements
    var i18nEls = document.querySelectorAll('[data-i18n]');
    for (var i = 0; i < i18nEls.length; i++) {
      var el = i18nEls[i];
      var key = el.getAttribute('data-i18n');
      if (key === 'titlebar') {
        // Titlebar uses localized "bash" label
        el.textContent = 'bash - 404';
      } else if (key === '404.terminalHint') {
        el.textContent = '# ' + (t[key] || el.textContent);
      } else if (key === '404.terminalHelp') {
        el.textContent = '# ' + (t[key] || el.textContent);
      } else if (key === '404.backButtonLabel') {
        el.textContent = t[key] || el.textContent;
      } else if (t[key]) {
        el.textContent = t[key];
      }
    }

    // Update home link
    var homeLink = document.getElementById('home-link');
    if (homeLink && homes[lang]) {
      homeLink.setAttribute('href', homes[lang]);
    }

    // Render posts listing
    var postsContainer = document.getElementById('posts-listing');
    var langPosts = posts[lang] || posts[defaultLang] || [];
    if (postsContainer && langPosts.length > 0) {
      var html = '';
      for (var j = 0; j < langPosts.length; j++) {
        var post = langPosts[j];
        var date = new Date(post.dateISO);
        var dateStr = date.toLocaleDateString(locale, { day: '2-digit', month: 'short', year: 'numeric' });
        html += '<a href="' + post.href + '" class="terminal-file" data-astro-prefetch>'
          + '<span class="file-permissions">-rw-r--r--</span>'
          + '<span class="file-date">' + dateStr + '</span>'
          + '<span class="file-name">' + post.slug + '/</span>'
          + '</a>';
      }
      postsContainer.innerHTML = html;
    }

    // Update the html lang attribute
    document.documentElement.setAttribute('lang', lang);
  })();
</script>

<style>
  .terminal-wrapper {
    max-width: 52rem;
    margin: 2rem auto;
    border-radius: 0.5rem;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
    font-family: 'Cascadia Code', 'Fira Code', 'JetBrains Mono', 'SF Mono', 'Consolas', 'Liberation Mono', monospace;
    font-size: 0.875rem;
    line-height: 1.6;
  }

  :global(:not(.dark)) .terminal-wrapper {
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15);
  }

  /* Title bar */
  .terminal-titlebar {
    display: flex;
    align-items: center;
    padding: 0.5rem 0.75rem;
    background: #2d2d2d;
    user-select: none;
  }

  :global(.dark) .terminal-titlebar {
    background: #1e1e1e;
  }

  .terminal-controls {
    display: flex;
    gap: 0.5rem;
  }

  .terminal-controls-spacer {
    width: 52px;
  }

  .terminal-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .dot-close { background: #ff5f57; }
  .dot-minimize { background: #febc2e; }
  .dot-maximize { background: #28c840; }

  .terminal-title {
    flex: 1;
    text-align: center;
    color: #999;
    font-size: 0.8rem;
  }

  /* Body */
  .terminal-body {
    padding: 1rem 1.25rem;
    background: #1e1e1e;
    color: #d4d4d4;
    min-height: 20rem;
  }

  :global(:not(.dark)) .terminal-body {
    background: #f5f5f5;
    color: #333;
  }

  /* Lines */
  .terminal-line {
    white-space: pre-wrap;
    word-break: break-all;
    margin-bottom: 0.25rem;
  }

  .terminal-empty {
    height: 1.2rem;
  }

  /* Prompt */
  .terminal-prompt {
    margin-right: 0.5rem;
  }

  .prompt-user { color: #4ec9b0; }
  .prompt-at { color: #d4d4d4; }
  .prompt-host { color: #9cdcfe; }
  .prompt-colon { color: #d4d4d4; }
  .prompt-path { color: #569cd6; }
  .prompt-dollar { color: #d4d4d4; margin-left: 0.15rem; }

  :global(:not(.dark)) .prompt-user { color: #067a4e; }
  :global(:not(.dark)) .prompt-at { color: #333; }
  :global(:not(.dark)) .prompt-host { color: #0451a5; }
  :global(:not(.dark)) .prompt-colon { color: #333; }
  :global(:not(.dark)) .prompt-path { color: #0000ff; }
  :global(:not(.dark)) .prompt-dollar { color: #333; }

  /* Command text */
  .terminal-command {
    color: #ce9178;
  }

  :global(:not(.dark)) .terminal-command {
    color: #a31515;
  }

  /* Error */
  .terminal-error {
    color: #f44747;
    font-weight: 500;
  }

  :global(:not(.dark)) .terminal-error {
    color: #cd3131;
  }

  /* Hint/comment lines */
  .terminal-hint,
  .terminal-help {
    color: #6a9955;
    font-style: italic;
  }

  :global(:not(.dark)) .terminal-hint,
  :global(:not(.dark)) .terminal-help {
    color: #008000;
  }

  /* ls file listing */
  .terminal-ls {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    margin-left: 0;
  }

  .terminal-ls :global(.terminal-file) {
    display: flex;
    gap: 1.5rem;
    text-decoration: none;
    color: inherit;
    padding: 0.125rem 0.5rem;
    border-radius: 0.25rem;
    transition: background-color 0.15s;
  }

  .terminal-ls :global(.terminal-file:hover) {
    background: rgba(255, 255, 255, 0.06);
  }

  :global(:not(.dark)) .terminal-ls :global(.terminal-file:hover) {
    background: rgba(0, 0, 0, 0.06);
  }

  .terminal-ls :global(.file-permissions) {
    color: #8b8b8b;
    flex-shrink: 0;
  }

  :global(:not(.dark)) .terminal-ls :global(.file-permissions) {
    color: #666;
  }

  .terminal-ls :global(.file-date) {
    color: #8b8b8b;
    min-width: 7.5rem;
    flex-shrink: 0;
  }

  :global(:not(.dark)) .terminal-ls :global(.file-date) {
    color: #666;
  }

  .terminal-ls :global(.file-name) {
    color: #569cd6;
    font-weight: 500;
  }

  :global(:not(.dark)) .terminal-ls :global(.file-name) {
    color: #0451a5;
  }

  .terminal-ls :global(.terminal-file:hover .file-name) {
    text-decoration: underline;
  }

  /* Links inside terminal */
  .terminal-link {
    color: #569cd6;
    text-decoration: none;
    font-weight: 500;
  }

  .terminal-link:hover {
    text-decoration: underline;
  }

  :global(:not(.dark)) .terminal-link {
    color: #0451a5;
  }

  /* Cursor */
  .terminal-cursor {
    color: #d4d4d4;
  }

  :global(:not(.dark)) .terminal-cursor {
    color: #333;
  }

  .terminal-cursor.blink {
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  /* Responsive */
  @media (max-width: 640px) {
    .terminal-wrapper {
      margin: 1rem 0.5rem;
      font-size: 0.75rem;
    }

    .terminal-body {
      padding: 0.75rem;
    }

    .terminal-ls :global(.terminal-file) {
      gap: 0.75rem;
    }

    .terminal-ls :global(.file-permissions) {
      display: none;
    }

    .terminal-ls :global(.file-date) {
      min-width: 5.5rem;
    }
  }
</style>
