---
import { fade } from "astro:transitions";
import { ViewTransitions } from "astro:transitions";
import BaseHead from "@/components/BaseHead.astro";
import Header from "@/components/Header.vue";
import HeaderAstro from "@/components/Header.astro";
import Footer from "@/components/FooterComponent.vue";
import ScrollToTop from "@/components/ScrollToTop.vue";
import { getLangFromUrl, useTranslate } from "@/i18n/utils";
import { HONEYPOT_ENTRY } from "@/lib/tarpit";
import { getPageTranslations } from "@/utils/translations";
interface Props {
  title?: string;
  description?: string;
  imageSize?: string;
  image?: { src: string; alt?: string };
  ogImage?: string;
  pageType?: "website" | "article";
  pageNav?: boolean;
  pageOperate?: boolean;
  noindex?: boolean;
  postSlug?: string;
  pubDate?: string | Date;
  tags?: string[];
  readingTime?: string;
}
const { ...head } = Astro.props;
const { imageSize, postSlug } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslate(lang);
const pageTranslations = await getPageTranslations(Astro.url, postSlug);
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead {...head} />
    <ViewTransitions />
  </head>
  <body class="bg-main text-main min-h-screen font-sans w-full bg-dot">
    <script is:inline define:vars={{ pageTranslationsJson: JSON.stringify(pageTranslations) }}>
      window.__pageTranslations__ = JSON.parse(pageTranslationsJson);
    </script>
    <script src="@/scripts/splat-decode.ts"></script>
    <a href="#main-content" class="skip-to-content">Skip to content</a>
    <Header client:only="vue" />
    <HeaderAstro />
    <main
      id="main-content"
      class=`grow ${imageSize === 'xl' ? 'max-w-100vw':'max-w-4xl'} mx-auto sm:pt-36 pt-26 pb-16 px-6 relative important:print:max-w-100vw important:print:p0 text-pretty`
      transition:animate={fade({ duration: "0.4s" })}
    >
      <slot />
      <ScrollToTop ariaLabel={t('scrollToTop.ariaLabel')} client:only="vue" />
    </main>
    <div class="max-w-4xl mx-auto sm:pt-18 pt-12 pb-16 px-6 relative">
      <Footer client:only="vue" />
    </div>
    <!-- Honeypot: invisible link to tarpit for misbehaving crawlers -->
    <a href={`/well/${HONEYPOT_ENTRY}`} style="position:absolute;left:-9999px;top:-9999px;width:1px;height:1px;overflow:hidden;" tabindex="-1" aria-hidden="true">resources</a>
  </body>
</html>
